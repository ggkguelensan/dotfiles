# Installs the curated VS Code extension list (Windows).
# run_onchange: the list below is embedded via includeTemplate, so editing
# .chezmoitemplates/vscode-extensions.txt re-triggers this script.
$ErrorActionPreference = "Continue"

if (-not (Get-Command code -ErrorAction SilentlyContinue)) {
    Write-Host "vscode-extensions: 'code' CLI not found, skipping"
    exit 0
}

$list = @'
{{ includeTemplate "vscode-extensions.txt" . }}
'@

$extensions = $list -split "`r?`n" | ForEach-Object { $_.Trim() } |
    Where-Object { $_ -ne "" -and -not $_.StartsWith("#") }

# Windows-only addition: the WSL remote extension lives on the client side.
$extensions += "ms-vscode-remote.remote-wsl"

foreach ($ext in $extensions) {
    Write-Host "vscode-extensions: ensuring $ext"
    code --install-extension $ext
    if ($LASTEXITCODE -ne 0) {
        Write-Warning "vscode-extensions: failed to install $ext"
    }
}
