# ~/.zshrc — managed by chezmoi (source: home/dot_zshrc in github.com/ggkguelensan/dotfiles)
# Cross-platform: WSL2 Ubuntu / macOS. Prefers runtime guards over templating.

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# VS Code shell integration (manual hook, recommended when using p10k/omz).
# Guarded: no-op outside VS Code terminals or if `code` is not on PATH.
if [[ "$TERM_PROGRAM" == "vscode" ]]; then
  _vsc_si="$(code --locate-shell-integration-path zsh 2>/dev/null)"
  [[ -n "$_vsc_si" && -r "$_vsc_si" ]] && builtin source "$_vsc_si"
  unset _vsc_si
fi

# macOS: Homebrew shellenv (runtime guard — no-op on Linux/WSL).
if [ "$(uname)" = "Darwin" ] && [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="powerlevel10k/powerlevel10k"

# Which plugins would you like to load?
# Add wisely, as too many plugins slow down shell startup.
plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  zsh-completions
  docker
  npm
  node
  sudo
  command-not-found
  history-substring-search
)

if [ -d "$ZSH" ]; then
  source "$ZSH/oh-my-zsh.sh"
  # NOTE: oh-my-zsh runs compinit itself — do NOT run it again below.
else
  # omz not installed (fresh machine): minimal cached completion init instead.
  autoload -Uz compinit && compinit -C
fi

# ----------------------------------------------------------------------------
# User configuration
# ----------------------------------------------------------------------------

# Полезные алиасы
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias cls='clear'
alias ..='cd ..'
alias ...='cd ../..'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'
alias zshconfig="nano ~/.zshrc"
alias ohmyzsh="nano ~/.oh-my-zsh"
alias reload="source ~/.zshrc"
alias tree="tree -C"
alias h="history"
alias df="df -h"
alias free="free -h"
alias ps="ps auxf"
alias mkdir="mkdir -pv"
alias ping="ping -c 5"
alias ports="netstat -tulanp"

# apt-алиасы — только там, где есть apt (Ubuntu/WSL; на macOS не определяются)
if command -v apt >/dev/null 2>&1; then
  alias update="sudo apt update && sudo apt upgrade"
  alias install="sudo apt install"
  alias search="apt search"
fi

# Git алиасы
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git log --oneline"
alias gd="git diff"
alias gb="git branch"
alias gco="git checkout"

# Docker алиасы (если используется)
alias dps="docker ps"
alias dpsa="docker ps -a"
alias di="docker images"
alias dc="docker-compose"

# Claude Code алиасы — только там, где установлен `claude` (runtime-guarded).
# ВНИМАНИЕ: `cc` перекрывает C-компилятор (/usr/bin/cc) ТОЛЬКО в интерактивном
# shell; сборочные тулзы вызывают cc через PATH, не через алиас. Если нужен
# компилятор интерактивно — `command cc` или /usr/bin/cc.
# caffeinate -i (idle) -m (disk) -s (system sleep, на питании от сети).
if command -v claude >/dev/null 2>&1; then
  alias cc='caffeinate -ims claude'                                    # всегда caffeinated: Mac не уснёт
  alias ccp='caffeinate -ims claude --dangerously-skip-permissions'    # + skip permissions (yolo)
fi

# Дополнительные настройки для улучшения терминала
export EDITOR='nano'
export BROWSER='lynx'
export HISTCONTROL=ignoreboth   # bash-ism, kept for compatibility when bash is invoked
export HISTSIZE=10000
export HISTFILESIZE=20000
SAVEHIST=$HISTSIZE              # zsh: actually persist history to $HISTFILE

# Цветовая схема для ls
export LS_COLORS='di=34:ln=35:so=32:pi=33:ex=31:bd=46;34:cd=43;34:su=41;30:sg=46;30:tw=42;30:ow=43;30'

# NVM removed — superseded by fnm (below) + a system-level node for non-interactive spawns.

# Настройки автодополнения
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"

# ----------------------------------------------------------------------------
# PATH and toolchains (runtime-guarded — each block is a no-op if tool absent)
# ----------------------------------------------------------------------------

[ -d /snap/bin ] && export PATH="$PATH:/snap/bin"
export PATH="$HOME/.local/bin:$PATH"

# pnpm
if [ -d "$HOME/.local/share/pnpm" ]; then
  export PNPM_HOME="$HOME/.local/share/pnpm"
  case ":$PATH:" in
    *":$PNPM_HOME:"*) ;;
    *) export PATH="$PNPM_HOME:$PATH" ;;
  esac
fi
# pnpm end

# fnm — exactly ONE init block (the old .zshrc had three duplicates, eval'ing
# `fnm env` 3x per shell). --use-on-cd switches node versions on directory change.
if [ -d "$HOME/.local/share/fnm" ]; then
  export PATH="$HOME/.local/share/fnm:$PATH"
fi
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# conda (miniforge3) — lazy-loaded: the hook costs ~100ms+ per shell, so it is
# only evaluated on the first `conda` invocation instead of at every startup.
if [ -d "$HOME/miniforge3" ]; then
  conda() {
    unfunction conda
    # >>> conda initialize >>> (deferred)
    __conda_setup="$("$HOME/miniforge3/bin/conda" 'shell.zsh' 'hook' 2>/dev/null)"
    if [ $? -eq 0 ]; then
      eval "$__conda_setup"
    elif [ -f "$HOME/miniforge3/etc/profile.d/conda.sh" ]; then
      . "$HOME/miniforge3/etc/profile.d/conda.sh"
    else
      export PATH="$HOME/miniforge3/bin:$PATH"
    fi
    unset __conda_setup
    # <<< conda initialize <<<
    conda "$@"
  }
fi

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
