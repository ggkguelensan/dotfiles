{
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "autoCompactWindow": 180000,
  "tui": "fullscreen",
  "statusLine": {
    "type": "command",
    "command": "{{ if eq .chezmoi.os "darwin" }}~/.local/bin/claude-code-statusline{{ else }}~/.claude/statusline.sh{{ end }}",
    "refreshInterval": {{ if eq .chezmoi.os "darwin" }}2{{ else }}60{{ end }}
  }{{ if ne .chezmoi.os "windows" }},
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/agent-notify \"needs input\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/agent-notify \"done\""
          }
        ]
      }
    ]
  }{{ end }}
}
